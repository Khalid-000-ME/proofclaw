{
  "name": "proofclaw",
  "version": "1.0.0",
  "description": "Quality-staked AI task market on Hedera",
  "private": true,
  "scripts": {
    "dev": "cd frontend && next dev",
    "build": "cd frontend && next build",
    "start": "cd frontend && next start",
    "lint": "cd frontend && next lint",
    "compile": "hardhat compile",
    "deploy:testnet": "hardhat run scripts/deploy.ts --network hederaTestnet",
    "deploy:mainnet": "hardhat run scripts/deploy.ts --network hederaMainnet",
    "seed-tasks": "hardhat run scripts/seed-tasks.ts --network hederaTestnet",
    "register-provider": "hardhat run scripts/register-provider.ts --network hederaTestnet",
    "provider": "node openclaw-skill/provider.js",
    "start:all": "concurrently \"npm run dev\" \"npm run provider\"",
    "test": "hardhat test"
  },
  "dependencies": {
    "@hashgraph/sdk": "^2.40.0",
    "@nomicfoundation/hardhat-ethers": "^3.0.0",
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@openzeppelin/contracts": "^5.0.0",
    "@phosphor-icons/react": "^2.0.15",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "autoprefixer": "^10.4.16",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^8.2.0",
    "dotenv": "^16.3.0",
    "ethers": "^6.9.0",
    "hardhat": "^2.19.0",
    "next": "^14.0.0",
    "ogl": "^1.0.11",
    "postcss": "^8.4.32",
    "radix-ui": "^1.4.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^2.10.0",
    "shadcn": "^4.1.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^3.4.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.3.0"
  },
  "devDependencies": {
    "@types/react-dom": "^18.2.0",
    "eslint": "^8.55.0",
    "eslint-config-next": "^14.0.0",
    "pkg": "^5.8.1"
  }
}
