{
  "name": "proofclaw-desktop",
  "version": "1.0.0",
  "main": "main.js",
  "private": true,
  "scripts": {
    "dev": "next dev -p 4000",
    "build": "next build",
    "start": "next start -p 4000",
    "lint": "next lint",
    "electron:dev": "concurrently \"next dev -p 4000\" \"wait-on http://localhost:4000 && electron .\"",
    "electron:build": "npm run build && electron-builder",
    "electron:build:win": "npm run build && electron-builder --win",
    "electron:build:all": "npm run build && electron-builder --mw"
  },
  "dependencies": {
    "next": "14.2.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "electron-is-dev": "^2.0.0",
    "ethers": "^6.9.0",
    "@hashgraph/sdk": "^2.40.0",
    "axios": "^1.6.2",
    "dotenv": "^16.3.1",
    "@phosphor-icons/react": "^2.0.15"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "concurrently": "^8.2.2",
    "wait-on": "^7.2.0",
    "typescript": "^5.3.3",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "tailwindcss": "^3.4.0",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.32"
  },
  "build": {
    "appId": "com.proofclaw.desktop",
    "productName": "ProofClaw",
    "asar": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      ".next/**/*",
      "public/**/*",
      "main.js",
      "preload.js",
      "package.json",
      "config.json",
      "deployments/**/*",
      "../deployments/**/*",
      "../openclaw-skill/**/*",
      "src/provider/**/*",
      ".env",
      ".env.local"
    ],
    "mac": {
      "category": "public.app-category.finance"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "publisherName": "ProofClaw"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
